GEMINI_API_KEY=put-your-key-here

# Audio device names (substrings of sounddevice.query_devices() entries)
# - On Pi:  "Snowball" and "HyperX"
# - On Mac: leave empty to use the system default mic/speaker
ROCKY_MIC_DEVICE=Snowball
ROCKY_SPEAKER_DEVICE=HyperX

# Camera backend: auto picks picamera2 if importable, else cv2 (webcam).
# Override with picamera2 | cv2 if needed.
ROCKY_CAMERA_BACKEND=auto

ROCKY_WEB_PORT=8000
